# =============================================================================
# Leadfinder — environment configuration
# Copy to .env and adjust for your environment:
#   cp .env.example .env
# =============================================================================

# --- Application ---
APP_NAME=leadfinder
# development | staging | production
APP_ENV=development
DEBUG=true
# Generate for production: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# --- Server (web app) ---
HOST=0.0.0.0
PORT=8000
# Production Compose: bind address for LAN access (0.0.0.0 = all interfaces)
APP_BIND=0.0.0.0
APP_PORT=8000
# Uvicorn workers (production only; keep 1 on 6 vCPU VM unless load-tested)
UVICORN_WORKERS=1

# --- PostgreSQL ---
POSTGRES_USER=leadfinder
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=leadfinder
# Local dev (host Postgres/Redis):
DATABASE_URL=postgresql+psycopg://leadfinder:change-me-strong-password@localhost:5432/leadfinder
# Docker Compose overrides DATABASE_URL to use service hostnames (db, redis).

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Logging ---
LOG_LEVEL=INFO
# console (dev) | json (production — easier to grep in docker logs)
LOG_FORMAT=console

# --- Background jobs (Phase 8) ---
JOB_QUEUE_NAME=leadfinder:jobs:queue
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=5
WORKER_POLL_SECONDS=5
SCHEDULER_POLL_SECONDS=60
WORKER_CONCURRENCY=1
STARTUP_WAIT_SECONDS=120
STARTUP_WAIT_INTERVAL=2

# --- Inspection pipeline ---
INSPECTION_BROWSER_ENABLED=false
INSPECTION_BROWSER_CONCURRENCY=1
INSPECTION_TIMEOUT_SECONDS=30
INSPECTION_QUEUE_NAME=leadfinder:inspection:queue
INSPECTION_SAVE_ARTIFACTS=true

# --- Persistent storage (inside container: /app/data via volume) ---
DATA_DIR=./data
EXPORT_DIR=./data/exports

# --- Optional internal Nginx reverse proxy (production profile) ---
NGINX_BIND=0.0.0.0
NGINX_PORT=80

# --- TomTom Search live provider (Phase 10) ---
# Enable only after adding a valid Search API key from https://developer.tomtom.com/
TOMTOM_ENABLED=false
TOMTOM_API_KEY=
TOMTOM_TIMEOUT_SECONDS=15
TOMTOM_SEARCH_RADIUS_METERS=15000

# --- Production checklist ---
# APP_ENV=production
# DEBUG=false
# LOG_FORMAT=json
# SECRET_KEY=<random 64-char hex>
# POSTGRES_PASSWORD=<strong password>
# INSPECTION_BROWSER_ENABLED=false  (enable only if Playwright installed in image)
